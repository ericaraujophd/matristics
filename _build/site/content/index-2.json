{"version":3,"kind":"Article","sha256":"3b62c32f7bd608909070987ec95abc4885664748fdaa5cab50c681cb3cabe5cb","slug":"index-2","location":"/biases/index.md","dependencies":[],"frontmatter":{"title":"Known LLM Biases in Early Church History","description":"Overview of the bias patterns LLMs exhibit when asked about early church history, particularly regarding women.","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Eric Araujo","given":"Eric","family":"Araujo"},"name":"Eric Araujo","email":"eric.araujo@calvin.edu","id":"contributors-myst-generated-uid-0","corresponding":true}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"keywords":["LLM evaluation","early church history","women in early Christianity","AI bias","gender bias","historical knowledge","natural language processing"],"numbering":{"title":{"offset":1}},"exports":[{"format":"md","filename":"index.md","url":"/index-7fff85f23bf3f55b88b9ad7e93c7b451.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Before collecting any data, it is possible to predict — from the structure of LLM training and from prior research on bias — the types of errors models are likely to make when asked about women in early Christianity. Documenting these patterns in advance serves two purposes: it informs the design of the rubric and question bank, and it establishes a baseline for comparing what is found against what was expected.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"KrbxuGNJbf"}],"key":"tFjOOeZLrP"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Three categories of bias are addressed in this section:","position":{"start":{"line":