nning:","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Sgmj5U6MiL"}],"key":"h4adJ9VJN9"},{"type":"text","value":" complete the setup in ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"lbWUasvv9a"},{"type":"link","url":"/setup","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Environment Setup","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"Ep9l1RP4bY"}],"urlSource":"setup.md","dataUrl":"/setup.json","internal":true,"protocol":"file","key":"bCa1BFe0ln"},{"type":"text","value":" and ensure ","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"xTxHYVcgbm"},{"type":"inlineCode","value":"ANTHROPIC_API_KEY","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"MmYntpgU4x"},{"type":"text","value":" is set.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"afDgOYJyG5"}],"key":"CL59gMvVtS"}],"key":"noaU7Lt3Iu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import anthropic\nimport json\nimport os\nimport time\nfrom datetime import datetime, timezone\nfrom pathlib import Path","key":"X4lX6HxVfA"},{"type":"outputs","id":"nwCgNLNsMwsJmuhuUe6md","children":[],"key":"n2kPXD7oP9"}],"key":"Fe6L5aGod9"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Configuration","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"FODacFtmi2"}],"identifier":"configuration","label":"Configuration","html_id":"configuration","implicit":true,"key":"rbR2PfdztL"}],"key":"od2DOMBTpn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"MODEL = \"claude-opus-4-6\"          # or claude-sonnet-4-6 for faster/cheaper runs\nTEMPERATURE = 0.0                   # deterministic for replication\nMAX_TOKENS = 1024\nOUTPUT_FILE = Path(\"data/responses/claude.jsonl\")\nOUTPUT_FILE.parent.mkdir(parents=True, exist_ok=True)\n\nclient = anthropic.Anthropic(api_key=os.environ[\"ANTHROPIC_API_KEY\"])","key":"fKNypyB95T"},{"type":"outputs","id":"AS5VsEJ0vGe9C8CHUxq2a","children":[],"key":"WzSgQnYSYs"}],"key":"QKTp0XQDda"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Load Question Bank","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OG9QLyihlU"}],"identifier":"load-question-bank","label":"Load Question Bank","html_id":"load-question-bank","implicit":true,"key":"jlML0UQhgE"}],"key":"fVXOjybpNJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import pandas as pd\n\n# Load questions from CSV (generated from figures/question_bank.csv)\nquestions = pd.read_csv(\"../figures/question_bank.csv\")\nprint(f\"Loaded {len(questions)} questions\")\nquestions.head()","key":"e8jP1GnNx5"},{"type":"outputs","id":"e1zYonnx5WLCE1AbkvZtl","children":[],"key":"CfBLOBfXGU"}],"key":"m4o1ibCVbP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"System Prompt","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"t65fyxwjR6"}],"identifier":"system-prompt","label":"System Prompt","html_id":"system-prompt","implicit":true,"key":"mMulhhS5fg"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"A neutral system prompt is used across all models to minimise prompt-induced variance.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"n7ETRXaaxa"}],"key":"c7N1LRG5SV"}],"key":"nuIXgWqTfz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"SYSTEM_PROMPT = \"\"\"You are a knowledgeable assistant answering questions about early church history.\nProvide accurate, detailed, and nuanced responses based on historical scholarship.\nAcknowledge uncertainty or scholarly debate where it exists.\nDo not refuse historically answerable questions on the grounds of contemporary theological controversy.\"\"\"","key":"FH93jeDJmY"},{"type":"outputs","id":"gOey7wjzG-a_dUGXxX__X","children":[],"key":"LUne0TfWPL"}],"key":"IlCplryrS9"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Run Collection","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BMtlGzRz6m"}],"identifier":"run-collection","label":"Run Collection","html_id":"run-collection","implicit":true,"key":"scoPQz2bVT"}],"key":"ke5aJVX5n6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def query_claude(question_text: str) -> dict:\n    \"\"\"Query Claude and return the response with metadata.\"\"\"\n    message = client.messages.create(\n        model=MODEL,\n        max_tokens=MAX_TOKENS,\n        temperature=TEMPERATURE,\n        system=SYSTEM_PROMPT,\n        messages=[{\"role\": \"user\", \"content\": question_text}],\n    )\n    return {\n        \"response\": message.content[0].text,\n        \"tokens_used\": message.usage.input_tokens + message.usage.output_tokens,\n        \"model_version\": message.model,\n    }\n\n\nresults = []\nwith open(OUTPUT_FILE, \"w\") as f:\n    for _, row in questions.iterrows():\n        print(f\"Querying {row['question_id']}...\", end=\" \")\n        try:\n            result = query_claude(row[\"question\"])\n            record = {\n                \"question_id\": row[\"question_id\"],\n                \"figure\": row[\"figure\"],\n                \"model\": MODEL,\n                \"model_version\": result[\"model_version\"],\n                \"prompt\": row[\"question\"],\n                \"response\": result[\"response\"],\n                \"temperature\": TEMPERATURE,\n                \"timestamp\": datetime.now(timezone.utc).isoformat(),\n                \"tokens_used\": result[\"tokens_used\"],\n            }\n            f.write(json.dumps(record) + \"\\n\")\n            results.append(record)\n            print(f\"done ({result['tokens_used']} tokens)\")\n        except Exception as e:\n            print(f\"ERROR: {e}\")\n        time.sleep(0.5)  # gentle rate limiting\n\nprint(f\"\\nSaved {len(results)} responses to {OUTPUT_FILE}\")","key":"qk4uU1fU2i"},{"type":"outputs","id":"sDO93oeEQRqNj7R5hT_YO","children":[],"key":"ovtBizCW3T"}],"key":"PcW91CxASw"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Inspect Results","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NzEmlwch8e"}],"identifier":"inspect-results","label":"Inspect Results","html_id":"inspect-results","implicit":true,"key":"y7UgCJiWpe"}],"key":"NcLGWLJbN0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Preview first response\nif results:\n    r = results[0]\n    print(f\"Q: {r['prompt']}\\n\")\n    print(f\"A: {r['response']}\\n\")\n    print(f\"Tokens: {r['tokens_used']} | Model: {r['model_version']}\")","key":"V4Amdy0V2R"},{"type":"outputs","id":"UD1-qthtf1RbjRsANR8D3","children":[],"key":"KgpjFDmI3i"}],"key":"ST5An6JKx3"}],"key":"x7Q85Hh4JQ"},"references":{"cite":{"order":[],"data":{}}}}