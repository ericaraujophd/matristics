n":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"ZgzjzJAoPh"}],"key":"DrKWP9OMNB"}],"key":"iwecXNdkK3"},{"type":"tableCell","children":[{"type":"paragraph","children":[{"type":"text","value":"References to Olympias in the context of the Chrysostom controversy, corroborating her institutional role and the political consequences of her loyalty to Chrysostom.","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"yxxY69dSBh"}],"key":"smX8R0yK18"}],"key":"PkU7iod997"}],"key":"OJnw07laCN"}],"key":"wVFd69J56Q"}],"enumerator":"1","key":"ayt5JICUj7"},{"type":"thematicBreak","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"b3fzDV6HG4"},{"type":"heading","depth":3,"position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"text","value":"Scholarly Debates","position":{"start":{"line":47,"column":1},"end":{"line":47,"column":1}},"key":"AsizVC78IH"}],"identifier":"scholarly-debates","label":"Scholarly Debates","html_id":"scholarly-debates","implicit":true,"key":"oxz4qLXn2F"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":50,"column":1}},"children":[{"type":"strong","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"The nature of Olympias’s ordained role","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"LXoeBHgDZv"}],"key":"zzuuX1oFqu"},{"type":"text","value":"\nOlympias was formally ordained a deacon (","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"hw81bgSXeT"},{"type":"emphasis","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"diakonissa","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"g4IFiNQrB1"}],"key":"AiomxTEvDF"},{"type":"text","value":") by Bishop Nectarius. Scholars debate the precise scope of this ordination: whether it was primarily liturgical (assisting with baptism of women), pastoral (visiting sick women), institutional (governing the monastery), or some combination. The ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"ZpjiwyPMLV"},{"type":"emphasis","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"Life","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"tNtgYGi3yE"}],"key":"t4qmcIp4Gi"},{"type":"text","value":" and Chrysostom’s letters suggest a pastoral and theological authority that exceeds a narrowly liturgical role. ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"End4A1OupZ"},{"type":"cite","kind":"narrative","label":"madigan2005ordained","identifier":"madigan2005ordained","children":[{"type":"text","value":"Madigan & Osiek (2005)","key":"ul2eMbpe08"}],"enumerator":"5","key":"mSokQopnZQ"},{"type":"text","value":" includes documentary evidence for ordained women in Constantinople and provides the essential scholarly context for evaluating the scope of Olympias’s diaconal authority.","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"NVBOfk8wzA"}],"key":"hPJC4mpiOb"},{"type":"paragraph","position":{"start":{"line":52,"column":1},"end":{"line":53,"column":1}},"children":[{"type":"strong","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Authority over men","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"xE6JBaprb8"}],"key":"NJZIvuKpyJ"},{"type":"text","value":"\nThe anonymous ","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"zdOIvTa5CI"},{"type":"emphasis","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"Life","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"ZXiWeHco6N"}],"key":"cLi4YlJcMv"},{"type":"text","value":" and Egeria’s contemporaneous account of the deaconess Marthana at the shrine of Thecla both document women exercising governing authority over mixed-gender monastic communities. Whether Olympias’s monastery was technically a “double monastery” (housing both women and men) is uncertain, but her institutional authority was clearly not confined to women alone.","position":{"start":{"line":52,"column":1},"end":{"line":52,"column":1}},"key":"uczW3PkTVu"}],"key":"YsQ1r2ZL8a"},{"type":"paragraph","position":{"start":{"line":55,"column":1},"end":{"line":56,"column":1}},"children":[{"type":"strong","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"children":[{"type":"text","value":"Olympias as theologian","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"nporGU9RN5"}],"key":"x7YXqIjayP"},{"type":"text","value":"\nChrysostom’s letters treat Olympias as a capable theological interlocutor, not merely a pious patron. He commends her understanding of scripture, addresses doctrinal questions to her, and responds to her theological anxieties at length. ","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"uazgP5JqIG"},{"type":"cite","kind":"narrative","label":"hartney2004chrysostom","identifier":"hartney2004chrysostom","children":[{"type":"text","value":"Hartney (2004)","key":"jVjQa8WYRx"}],"enumerator":"6","key":"ZBVvOAAQOh"},{"type":"text","value":" argues that this epistolary theology constitutes Olympias’s own theological contribution, mediated through the letters but initiated by her questions and responses.","position":{"start":{"line":55,"column":1},"end":{"line":55,"column":1}},"key":"vMXlKSGqKY"}],"key":"Q5CmSFXUlO"},{"type":"paragraph","position":{"start":{"line":58,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"strong","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"children":[{"type":"text","value":"The politics of holiness","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"NxcPCWkX2T"}],"key":"ReyZdMYMoG"},{"type":"text","value":"\nOlympias’s refusal to recognize Chrysostom’s replacement was a political act with ecclesiastical consequences. Her subsequent trial and exile demonstrate that women in prominent diaconal roles could be targeted for institutional dissent — a dimension often omitted from accounts that treat her primarily as a “patron saint of generosity.”","position":{"start":{"line":58,"column":1},"end":{"line":58,"column":1}},"key":"kpG36Zk2g0"}],"key":"Em5q98QfqU"},{"type":"thematicBreak","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"OIDXOQ6eG5"},{"type":"heading","depth":3,"position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"children":[{"type":"text","value":"Evaluation Questions","position":{"start":{"line":63,"column":1},"end":{"line":63,"column":1}},"key":"GA1HO1y1rK"}],"identifier":"evaluation-questions","label":"Evaluation Questions","html_id":"evaluation-questions","implicit":true,"key":"mkAUyoeAPb"},{"type":"paragraph","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"children":[{"type":"text","value":"The following questions from the project’s question bank are assigned to Olympias. Each question is used as an evaluation prompt submitted verbatim to each LLM under study.","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"XOoUmufwc7"}],"key":"gX9Nv9BNgr"},{"type":"container","kind":"table","children":[{"type":"table","children":[{"type":"tableRow","children":[{"type":"tableCell","header":true,"children":[{"type":"heading","depth":2,"position":{"start":{"line":70,"column":1},"end":{"line":70,"column":1}},"children":[],"key":"dPUGYy4ALr"}],"key":"dSVQAyvvm8"},{"type":"tableCell","header":true,"children":[{"type":"paragraph","children":[{"type":"text","value":"Question","position":{"start":{"line":71,"column":1},"end"