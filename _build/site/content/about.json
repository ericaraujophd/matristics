{"version":3,"kind":"Article","sha256":"0590aab0c791fe9f4486398b55edb145e8e7817395cfedc554a1f1ed2e0db264","slug":"about","location":"/about.md","dependencies":[],"frontmatter":{"title":"About","description":"About this project, its goals, and how to get in touch.","authors":[{"nameParsed":{"literal":"Eric Araujo","given":"Eric","family":"Araujo"},"name":"Eric Araujo","email":"eric.araujo@calvin.edu","id":"contributors-myst-generated-uid-0","corresponding":true}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"keywords":["LLM evaluation","early church history","women in early Christianity","AI bias","gender bias","historical knowledge","natural language processing"],"exports":[{"format":"md","filename":"about.md","url":"/about-9cc1be65c51ad2dcdf82c08a30534bbb.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"About This Project","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"awfGYVDnOD"}],"identifier":"about-this-project","label":"About This Project","html_id":"about-this-project","implicit":true,"key":"U1Nddr8An9"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"This project sits at the intersection of two fields: the study of women in early Christianity, and the evaluation of large language models for factual accuracy and fairness.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"mh1tH3hK7w"}],"key":"Z2GNJw9sbR"},{"type":"heading","depth":3,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Motivation","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"i4fu2UR80t"}],"identifier":"motivation","label":"Motivation","html_id":"motivation","implicit":true,"key":"cs66f8tKo3"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Large language models are increasingly used as research aids, educational tools, and sources of historical information. Yet the training data that shapes their knowledge reflects the same biases present in the historical record itself: the voices of men dominate, women appear as footnotes, and contested scholarship is often resolved without acknowledgement of the debate.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"dpCWWytGFn"}],"key":"ZXnjmb902E"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Early church history is an especially revealing test case. The women who led house churches, founded monasteries, wrote theology, and challenged orthodoxy in the first five centuries of Christianity are documented — but in sparse, often polemical, often mediated sources. An LLM asked about Macrina the Younger or Olympias of Constantinople must navigate fragmentary evidence, gendered hagiographic conventions, and contested translations. How it performs reveals something about what it has learned and what it has not.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"c0e8of2Wme"}],"key":"RhNr0y1VfN"},{"type":"heading","depth":3,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Project Goals","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"GdFoYd7ysY"}],"identifier":"project-goals","label":"Project Goals","html_id":"project-goals","implicit":true,"key":"LOJnIxHOGs"},{"type":"list","ordered":true,"start":1,"spread":false,"position":{"start":{"line":18,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Build a rigorous, replicable evaluation methodology for assessing LLM responses in specialized historical domains.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"E2QNGg8lug"}],"key":"psEN8MX7rQ"}],"key":"loWQEngwpc"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Document the specific bias patterns that emerge when LLMs are asked about women in early Christianity.","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"x5leEwBZHz"}],"key":"BCzQP7kJ9X"}],"key":"bIsdv31XLm"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Produce a public benchmark comparing major LLMs across a question bank of 42+ items spanning figures of varying obscurity and questions of varying difficulty.","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"sVJ6yIKpC8"}],"key":"OoIYte3szB"}],"key":"eYGYtxbIMO"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Make all materials openly available so other researchers can replicate, extend, or critique the evaluation.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"cL7l6q1qiM"}],"key":"j5PQqW0ckg"}],"key":"TT0BuX9Nup"}],"key":"YCLHjoijXh"},{"type":"heading","depth":3,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Author","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"YHUKDEihxo"}],"identifier":"author","labe