{"version":3,"kind":"Article","sha256":"f1413b197ccb7e50d72a2db756853876c2a3195b5754de41a4740e2d24bd8cac","slug":"contested-scholarship","location":"/biases/contested-scholarship.md","dependencies":[],"frontmatter":{"title":"Contested Scholarship","description":"How LLMs handle open scholarly debates, and why this is a particular problem for early church history.","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Eric Araujo","given":"Eric","family":"Araujo"},"name":"Eric Araujo","email":"eric.araujo@calvin.edu","id":"contributors-myst-generated-uid-0","corresponding":true}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"keywords":["LLM evaluation","early church history","women in early Christianity","AI bias","gender bias","historical knowledge","natural language processing"],"numbering":{"title":{"offset":1}},"exports":[{"format":"md","filename":"contested-scholarship.md","url":"/contested-scholarshi-6260e45e18998150a00dce9b39d1936f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Early church history involves significant scholarly debate, and LLMs struggle to handle epistemic uncertainty gracefully in this domain.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"wHvFZrYYp2"}],"key":"ulA8uOJ88k"},{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Key Contested Questions","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"P3OFPFJ4Kt"}],"identifier":"key-contested-questions","label":"Key Contested Questions","html_id":"key-contested-questions","implicit":true,"key":"yACGLihpcJ"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"strong","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Junia’s gender and apostolic identity:","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"p5lFEskiGh"}],"key":"F3EZsOcJix"},{"type":"text","value":" Whether the Junia of Romans 16:7 was female, and whether she was an apostle, is both a textual/historical question (the manuscript evidence strongly supports a female name; patristic commentators before the medieval period read her as female) and a theologically contested question in contemporary Christianity. LLMs may resolve this ambiguity in either direction without acknowledging the evidence.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"HM0tE2Ts7O"}],"key":"t7brcKd6mg"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"The ","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"dLO24hrkuI"},{"type":"emphasis","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"prostatis","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"a25yYueqmB"}],"key":"zu8uX3V0J5"},{"type":"text","value":" of Romans 16:2:","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"lYVcYz5lRi"}],"key":"rjqV9uADB9"},{"type":"text","value":" The Greek term used for Phoebe carries civic connotations of authority and leadership. Whether to translate it as “patron,” “helper,” or “leader” is a textual question with ideological stakes. Models trained on translations that domesticate the term will reproduce that choice without flagging it as contested.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"ME8S8AehjT"}],"key":"mGlp5JcRfU"},{"type":"paragraph","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"strong","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Women’s ordained ministry in the early church:","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"VW2Vca9zdF"}],"key":"OfJBQRrhsy"},{"type":"text","value":" ","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"ApzVjpVTT7"},{"type":"cite","kind":"narrative","label":"madigan2005ordained","identifier":"madigan2005ordained","children":[{"type":"text","value":"Madigan & Osiek (2005)","key":"hpWHcPjD6F"}],"enumerator":"1","key":"kmrN0DSD1E"},{"type":"text","value":" documents substantial epigraphic and textual evidence for ordained women in the early centuries, and ","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"kqxmx1BWi4"},{"type":"cite","kind":"narrative","label":"torjesen1993women","identifier":"torjesen1993women","children":[{"type":"text","value":"Torjesen (1993)","key":"oZnl7ifYr1"}],"enumerator":"2","key":"TakA9IiQ0E"},{"type":"text","value":" argues from liturgical and textual sources that women exercised formal priestly leadership in the pre-Nicene church. This evidence is contested in contemporary theological debate. Models may present either the conservative or the revisionist scholarly position as though it were settled.","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"JwwU5hsDRO"}],"key":"ah5el0TN4x"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"strong","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Canonicity and apocryphal sources:","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"b2BUaRu0vA"}