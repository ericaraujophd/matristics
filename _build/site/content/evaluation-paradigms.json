{"version":3,"kind":"Article","sha256":"2552947ce81e0079de0c7d5c2c36984bddcfb5ec413103ab2bdaad90d038ae2b","slug":"evaluation-paradigms","location":"/methodology/evaluation-paradigms.md","dependencies":[],"frontmatter":{"title":"Evaluation Paradigms","description":"The three evaluation paradigms used in this project — pairwise comparison, pointwise scoring, and reference-guided scoring — and how they are combined.","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Eric Araujo","given":"Eric","family":"Araujo"},"name":"Eric Araujo","email":"eric.araujo@calvin.edu","id":"contributors-myst-generated-uid-0","corresponding":true}],"license":{"content":{"id":"CC-BY-4.0","url":"https://creativecommons.org/licenses/by/4.0/","name":"Creative Commons Attribution 4.0 International","free":true,"CC":true}},"keywords":["LLM evaluation","early church history","women in early Christianity","AI bias","gender bias","historical knowledge","natural language processing"],"numbering":{"title":{"offset":1}},"exports":[{"format":"md","filename":"evaluation-paradigms.md","url":"/evaluation-paradigms-33a03eabb305d60314f7fdcad9dc8dc5.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"Three main paradigms dominate the human LLM evaluation literature. This project uses a hybrid of all three, assigning each paradigm to the rubric dimensions where it is best suited.","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"tc9EtaB1RE"}],"key":"a9l8amDuio"},{"type":"heading","depth":2,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Pairwise Comparison","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"f7fFljF4OZ"}],"identifier":"pairwise-comparison","label":"Pairwise Comparison","html_id":"pairwise-comparison","implicit":true,"key":"IqDCbA4gdl"},{"type":"paragraph","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"children":[{"type":"text","value":"Two LLM responses to the same prompt are shown side by side. Human judges select the better response or declare a tie. This approach is sensitive to subtle quality differences and produces high inter-annotator agreement because the task is comparative rather than absolute.","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"e99Xz7QgDG"}],"key":"b9bcuDMwah"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Used in this project for","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"EBuicXQWJX"}],"key":"J5R7hFqKbU"},{"type":"text","value":": overall model ranking (Elo-style tournament across models), and as a calibration check on pointwise scores.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"eN0lkpoRjL"}],"key":"nDQ732d17i"},{"type":"heading","depth":2,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"Pointwise Scoring (Likert Scales)","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"X4yXsw2WUg"}],"identifier":"pointwise-scoring-likert-scales","label":"Pointwise Scoring (Likert Scales)","html_id":"pointwise-scoring-likert-scales","implicit":true,"key":"rHRidTIHPo"},{"type":"paragraph","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"A single response is rated on a 1–5 scale along each rubric dimension independently. This allows fine-grained comparison across models, questions, and figures, and produces data suitable for quantitative analysis.","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"xkEATQ0NtU"}],"key":"LoksW87smh"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"strong","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"Used in this project for","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"CPl31H92Re"}],"key":"PgedueVO5D"},{"type":"text","value":": all seven rubric dimensions (see ","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"OZ8Hl34ueP"},{"type":"link","url":"/rubric","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"text","value":"Evaluation Rubric","key":"zrjRYPY4Hw"}],"urlSource":"rubric","dataUrl":"/rubric.json","internal":true,"protocol":"file","key":"AFJwLhgWnd"},{"type":"text","value":").","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"oENmAqwkRQ"}],"key":"fk3Fe5DLai"},{"type":"heading","depth":2,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Reference-Guided Scoring","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"GxcZrTGqNu"}],"identifier":"reference-guided-scoring","label":"Reference-Guided Scoring","html_id":"reference-guided-scoring","implicit":true,"key":"MlMDl3cfUU"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"Annotators compare an LLM response against a gold-standard reference answer prepared by domain experts. The reference provides a shared factual baseline and reduces the burden on annotators who may not independently know the correct answer.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"aJGD3onZfW"}],"key":"vheNmeQ9T8"},{"type":"paragraph","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"strong","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Used in this project for","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"R3O0svZEPI"}],"key":"dTqtv94C63"},{"type":"text","value":": Factual Accuracy, Source Awareness, and Anachronism dimensions. Reference answers for all 42 questions are prepared in advance by the project team and validated against peer-reviewed scholarship.","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"a1Xceuk49K"}],"key":"VK1ztJehvK"},{"type":"heading","depth":2,"position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"Why a Hybrid Approach?","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"flDQUOFsWj"}],"identifier":"why-a-hybrid-approach","label":"Why a Hybrid Approach?","html_id":"why-a-hybrid-approach","implicit":true,"key":"ObEB7Awf1S"},{"type":"paragraph","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"cite","kind":"narrative","label":"zheng2023judging","identifier":"zheng2023judging","children":[{"type":"text","value":"Zheng ","key":"a6N2qMbGxA"},{"type":"emphasis","children":[{"type":"text","value":"et al.","key":"hINRql4vEV"}],"key":"VgsLUYplct"},{"type":"text","value":" (2023)","key":"oG9CFd5lw7"}],"enumerator":"1","key":"q6vBUs3zVm"},{"type":"text","value":" introduced the LLM-as-judge paradigm and demonstrated that pairwise comparison achieves the highest consistency with human preference rankings — but pairwise comparison alone does not produce the dimension-level scores needed to diagnose ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"fgL5oJYbcU"},{"type":"emphasis","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"where","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"Dtrf14cF5A"}],"key":"UHE64dnmGV"},{"type":"text","value":" a model fails. ","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"R4fCrLpm9t"},{"type":"cite","kind":"narrative","label":"liu2023geval","identifier":"liu2023geval","children":[{"type":"text","value":"Liu ","key":"rnqWQeMWHc"},{"type":"emphasis","children":[{"type":"text","value":"et al.","key":"svSFmFXjUK"}],"key":"zDNn2c4EKQ"},{"type":"text","value":" (2023)","key":"T4AQ5t3jtx"}],"enumerator":"2","key":"zKadGjQOfm"},{"type":"text","value":" addressed this by proposing G-Eval, a rubric-based pointwise scoring framework using chain-of-thought reasoning, which achieves better correlation with human judgments than older string-overlap metrics. The hybrid design here draws on both: pairwise comparison for overall model ranking, and pointwise Likert scoring for per-dimension diagnosis.","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"Oq7FpsbeqJ"}],"key":"ysmK9EM2b7"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Reference-guided scoring is added as a third component because the domain-expert knowledge required to evaluate responses on Factual Accuracy, Anachronism, and Source Awareness cannot be assumed of all annotators. Gold-standard reference answers reduce annotator burden and improve reliability on dimensions where the correct answer is determinable from the historical record. ","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"hvDhZONDIR"},{"type":"cite","kind":"narrative","label":"wang2024survey","identifier":"wang2024survey","children":[{"type":"text","value":"Wang & others (2024)","key":"ni38kgfZgw"}],"enumerator":"3","key":"kafCj2jhpX"},{"type":"text","value":" provides a comprehensive survey of this combined methodology as of 2024.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"xXjBvFtNUI"}],"key":"EJm05SYO4U"},{"type":"admonition","kind":"note","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"Note","key":"x3gnY9oKfb"}],"key":"SQ8bnwcBAJ"},{"type":"paragraph","position":{"start":{"line":35,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"A key constraint on this project: LLM-as-judge pipelines are not used for the ","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"rcb3Mpamue"},{"type":"strong","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"children":[{"type":"text","value":"Gender Bias","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"rVJFUOSWWX"}],"key":"DanqikI0oG"},{"type":"text","value":" dimension.\nAn LLM judge evaluating another model’s treatment of Macrina may reproduce the same androcentric\ngaps as the system under evaluation. Human adjudication by domain experts is required for this dimension.","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"w7vWW8U0MI"}],"key":"WsL9Ac7Qtb"}],"key":"C1Kqu3DhXH"}],"key":"fQeOLrFEEe"}],"key":"r1T6SUgSzF"},"references":{"cite":{"order":["zheng2023judging","liu2023geval","wang2024survey"],"data":{"zheng2023judging":{"label":"zheng2023judging","enumerator":"1","doi":"10.48550/arXiv.2306.05685","html":"Zheng, L., Chiang, W.-L., Sheng, Y., Zhuang, S., Wu, Z., Zhuang, Y., Lin, Z., Li, Z., Li, D., Xing, E. P., Zhang, H., Gonzalez, J. E., & Stoica, I. (2023). <i>Judging LLM-as-a-Judge with MT-Bench and Chatbot Arena</i>. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.48550/arXiv.2306.05685\">10.48550/arXiv.2306.05685</a>","url":"https://doi.org/10.48550/arXiv.2306.05685"},"liu2023geval":{"label":"liu2023geval","enumerator":"2","doi":"10.18653/v1/2023.emnlp-main.153","html":"Liu, Y., Iter, D., Xu, Y., Wang, S., Xu, R., & Zhu, C. (2023). G-Eval: NLG Evaluation using GPT-4 with Better Human Alignment. <i>Proceedi